# Secrets / local config
server/runtime/.env
.env
.env.local
.env.*.local
clients/pwa/.env.local
site/.env.local
# Telegram app credentials (Mario exports the my.telegram.org/apps
# page as a plain file in repo root; kept out of git). Leading slash
# anchors to repo root so we don't accidentally swallow paths like
# server/skills/telegram/ or any *.py file named telegram_*.
/telegram
/telegram.*
*.session
*.session-journal

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
*.egg-info/
dist/
build/

# Python tooling
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Runtime
*.db
*.db-shm
*.db-wal
server/runtime/logs/
logs/

# Persona-local data (audiobook library, sqlite DB) — large, user-provided
server/personas/*/data/
server/runtime/models/

# Sound assets — raw extraction workspace; only curated *.wav belong in git
server/personas/*/sounds/raw/
wii-system-soundtrack-flac/

# macOS
.DS_Store

# PWA client (clients/pwa)
clients/pwa/node_modules/
clients/pwa/dist/
clients/pwa/build/

# Marketing site (site/)
site/node_modules/
site/dist/
site/build/
