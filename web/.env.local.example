# Comma-separated `name:url` pairs. The web UI shows a dropdown in the
# header that switches the active server connection. Each entry must
# correspond to a Huxley server process running on the named URL —
# different personas can't share a server (one persona per process today).
#
# Start one server per persona on different ports:
#
#   cd packages/core
#   uv run huxley                                                  # AbuelOS @ 8765
#   HUXLEY_PERSONA=basicos HUXLEY_SERVER_PORT=8766 uv run huxley   # BasicOS @ 8766
#
# Then copy this file to web/.env.local (Vite picks it up automatically):
VITE_HUXLEY_PERSONAS=abuelos:ws://localhost:8765,basicos:ws://localhost:8766
